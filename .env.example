HOST=0.0.0.0
PORT=8787
SERPAPI_API_KEY=your_serpapi_key_here

# Comma-separated origins allowed to call the backend.
# Add your deployed frontend URL after deploying the Vite app.
CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost:5173,http://localhost:5174

# SerpApi defaults for Google Shopping in India.
SERPAPI_LOCATION=India
SERPAPI_GOOGLE_DOMAIN=google.co.in
SERPAPI_GL=in
SERPAPI_HL=en

# Keep these conservative while testing because every uncached query can count.
SERPAPI_MAX_QUERIES=5
SERPAPI_RESULTS_PER_QUERY=10
SERPAPI_TIMEOUT_MS=18000

# Free pincode/Open-Meteo environment lookup timeout.
ENVIRONMENT_API_TIMEOUT_MS=8000
